# Firebase Configuration (required for dashboard data on Vercel)
# Option A (recommended for Vercel): paste full service account JSON as one line
FIREBASE_SERVICE_ACCOUNT_JSON=
# Option B (local): path to downloaded JSON file
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./firebase-service-account.json

# Jobs dashboard (at least one pair)
USAJOBS_API_KEY=
USAJOBS_EMAIL=
# Optional
BRIGHTDATA_API_TOKEN=
ANTHROPIC_API_KEY=

# Bright Data MCP API Token (Optional)
# Get your token from https://brightdata.com/
# Leave empty to use local custom MCP server only
BRIGHTDATA_API_TOKEN=paste_it_here

# Anthropic Claude API Key
# Add your own key from Anthropic Console
ANTHROPIC_API_KEY=your_anthropic_api_key_here
