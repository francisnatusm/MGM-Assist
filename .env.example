# Firebase (required for dashboard data in production)
# Option A (recommended on Vercel): paste full service account JSON
FIREBASE_SERVICE_ACCOUNT_JSON=
# Option B (local only): path to downloaded JSON file
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./firebase-service-account.json

# Jobs dashboard data source
USAJOBS_API_KEY=
USAJOBS_EMAIL=

# Bright Data — token required for Montgomery Pulse / city scraping on Vercel
BRIGHTDATA_API_TOKEN=
# Web Unlocker zone name from Bright Data dashboard (e.g. web_unlocker1). Optional; server tries common zones.
BRIGHTDATA_UNLOCKER_ZONE=

# Anthropic (optional for AI summarization features)
ANTHROPIC_API_KEY=

# Vercel Cron (set on mgm-assist backend project — auto-generated if you enable Crons in Vercel UI)
CRON_SECRET=
